# Threat Feed Gateway example environment
# Copy this file to .env and change values before production use.

DEBUG=0
SECRET_KEY=CHANGE_ME
# Portable default:
# DJANGO_ALLOWED_HOSTS=* allows one-command installs to work on any IP, hostname, or domain.
# For hardened production deployments, replace * with explicit values, for example:
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tfg.company.com
DJANGO_ALLOWED_HOSTS=*

POSTGRES_DB=threatfeed
POSTGRES_USER=threatfeed
POSTGRES_PASSWORD=CHANGE_ME

# HTTPS is optional.
# If you terminate TLS on a reverse proxy, enable these.
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

# USOM sync
USOM_ADAPTIVE_CONCURRENCY_ENABLED=1
USOM_ADAPTIVE_CONCURRENCY_LEVELS=10,9,7
USOM_FETCH_CONCURRENCY=10
DOMAIN_FETCH_CONCURRENCY=10

# First-login admin account
# Change this password after first login.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME
DJANGO_SUPERUSER_EMAIL=admin@example.local
