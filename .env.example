# USOM IOC Gateway environment example
# install.sh bu dosyadan .env oluşturur.
# Secret/password değerleri kurulumda otomatik üretilir.

TFG_HTTP_PORT=80

DEBUG=0
SECRET_KEY=CHANGE_ME
DJANGO_ALLOWED_HOSTS=*

POSTGRES_DB=threatfeed
POSTGRES_USER=threatfeed
POSTGRES_PASSWORD=CHANGE_ME

SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

DOMAIN_FETCH_CONCURRENCY=10
ORCHESTRATOR_INTERVAL_SECONDS=900

USOM_API_BASE=https://siberguvenlik.gov.tr/api/address/index
USOM_TYPES=ip,domain,url,ip6,ip6net
USOM_PER_PAGE=5000
USOM_MAX_PAGES_PER_TYPE=0
USOM_FETCH_CONCURRENCY=10
USOM_REQUEST_TIMEOUT=90
USOM_PAGE_RETRY_COUNT=5
USOM_PAGE_RETRY_BACKOFF_SECONDS=10
USOM_PAGE_DELAY_SECONDS=0.02
USOM_EMPTY_PAGE_RETRY_COUNT=5
USOM_EMPTY_PAGE_RETRY_BACKOFF_SECONDS=2
USOM_MAX_EMPTY_PAGES=3
USOM_MAX_NO_NEW_PAGES=3
USOM_MIN_COMPLETION_RATIO=0.95
USOM_MAX_TOTALCOUNT_DRIFT=1000
USOM_FINAL_CONSISTENCY_CHECK=1
USOM_FINAL_CONSISTENCY_POLICY=warn

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME
DJANGO_SUPERUSER_EMAIL=admin@example.local
